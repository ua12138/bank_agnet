HZ_AIOPS_APP_NAME=hz-bank-aiops-incident
HZ_AIOPS_ENV=dev
HZ_AIOPS_WORKFLOW_ENGINE=langgraph
HZ_AIOPS_LANGGRAPH_FALLBACK_TO_CLASSIC=true
HZ_AIOPS_REACT_COT_ENABLED=false
HZ_AIOPS_REACT_COT_MAX_CHARS=240
HZ_AIOPS_REACT_COT_MAX_ENTRIES=16
HZ_AIOPS_REACT_MEMORY_ENABLED=true
HZ_AIOPS_REACT_CONTEXT_WINDOW_STEPS=3
HZ_AIOPS_REACT_SUMMARY_MAX_CHARS=480
HZ_AIOPS_REACT_SUMMARY_MAX_ENTRIES=12
HZ_AIOPS_LLM_PROVIDER=siliconflow
HZ_AIOPS_LLM_API_KEY=
HZ_AIOPS_LLM_BASE_URL=https://api.siliconflow.cn/v1
HZ_AIOPS_LLM_MODEL=Qwen/Qwen2.5-14B-Instruct
HZ_AIOPS_LLM_REQUEST_TIMEOUT_SEC=20
HZ_AIOPS_ENABLE_DEDUP=true
HZ_AIOPS_DEDUP_WINDOW_SEC=300
HZ_AIOPS_ENABLE_HUMAN_APPROVAL=true
HZ_AIOPS_TASK_DB_KIND=sqlite
HZ_AIOPS_SQLITE_PATH=./data/runtime/diagnosis.db
HZ_AIOPS_FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/replace_me
HZ_AIOPS_RAG_MCP_BASE_URL=http://127.0.0.1:8091
HZ_AIOPS_WORKER_ID=diag-worker-1
HZ_AIOPS_MAX_RETRY=3
HZ_AIOPS_WORKER_POLL_INTERVAL_SEC=1.0
HZ_AIOPS_DEMO_RAG_MCP_BASE_URL=http://127.0.0.1:8091
HZ_AIOPS_DEMO_RAG_TIMEOUT_SEC=60
HZ_AIOPS_DEMO_RAG_QUERY_TOP_K=1
HZ_AIOPS_DEMO_RAG_CANDIDATE_MULTIPLIER=1
HZ_AIOPS_DEMO_RAG_FAST_MODE=true
HZ_AIOPS_DEMO_RAG_USE_MEMORY=false
